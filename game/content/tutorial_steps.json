{
  "tutorial_steps": [
    {
      "id": "step_welcome",
      "index": 0,
      "prompt_text": "Welcome to Cormorant Ridge Mall. You have a store to run. Start walking.",
      "trigger_event": "gameplay_ready",
      "trigger_condition": {},
      "is_skippable": true
    },
    {
      "id": "step_walk_to_store",
      "index": 1,
      "prompt_text": "Head to your store in the mall. Look for the storefront with your sign.",
      "trigger_event": "storefront_zone_entered",
      "trigger_condition": {},
      "is_skippable": true
    },
    {
      "id": "step_enter_store",
      "index": 2,
      "prompt_text": "Step inside your store. Press the interact key when facing the entrance.",
      "trigger_event": "store_entered",
      "trigger_condition": {},
      "is_skippable": false
    },
    {
      "id": "step_open_inventory",
      "index": 3,
      "prompt_text": "Open your inventory panel to see what stock you have available to sell.",
      "trigger_event": "panel_opened",
      "trigger_condition": {"panel_name": "inventory"},
      "is_skippable": false
    },
    {
      "id": "step_place_item",
      "index": 4,
      "prompt_text": "Stock a shelf — drag an item from inventory onto an empty shelf slot.",
      "trigger_event": "item_stocked",
      "trigger_condition": {},
      "is_skippable": false
    },
    {
      "id": "step_open_pricing",
      "index": 5,
      "prompt_text": "Open the pricing panel. Every item needs a price before customers will buy it.",
      "trigger_event": "panel_opened",
      "trigger_condition": {"panel_name": "pricing"},
      "is_skippable": false
    },
    {
      "id": "step_set_price",
      "index": 6,
      "prompt_text": "Set a price for your stocked item. Price too high and customers walk. Too low and you lose.",
      "trigger_event": "price_set",
      "trigger_condition": {},
      "is_skippable": false
    },
    {
      "id": "step_wait_for_customer",
      "index": 7,
      "prompt_text": "Customers will arrive on their own. Stay in the store and let them browse.",
      "trigger_event": "customer_spawned",
      "trigger_condition": {},
      "is_skippable": true
    },
    {
      "id": "step_first_sale",
      "index": 8,
      "prompt_text": "A customer is ready to buy. Watch the sale complete — that sound is money.",
      "trigger_event": "customer_purchased",
      "trigger_condition": {},
      "is_skippable": false
    },
    {
      "id": "step_end_day",
      "index": 9,
      "prompt_text": "End the day when you're ready. Open the day panel and confirm to close up shop.",
      "trigger_event": "day_ended",
      "trigger_condition": {},
      "is_skippable": false
    }
  ]
}
