script = ExtResource("1")

; ============================================================
; Player Controller — fixed isometric orbit camera over the store
; floor. Replaces the legacy PlayerEntrySpawn / StorePlayerBody flow:
; absence of a `PlayerEntrySpawn` Marker3D causes
; `GameWorld._on_hub_enter_store_requested` to fall through to
; `_activate_store_camera`, which makes this StoreCamera current.
; The pivot clamp at z=2.3 closes the front entrance gap so the
; camera cannot orbit out through the open storefront opening.
; ============================================================

[node name="PlayerController" parent="." instance=ExtResource("26_retrogames")]
zoom_default = 9.0
zoom_min = 4.0
zoom_max = 16.0
pitch_default_deg = 52.0
pitch_min_deg = 30.0
pitch_max_deg = 75.0
store_bounds_min = Vector3(-4.5, 0.0, -3.0)
store_bounds_max = Vector3(4.5, 0.0, 3.0)

