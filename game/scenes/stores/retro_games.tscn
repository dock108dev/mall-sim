; ============================================================
; EntranceDoor — semi-transparent glass door filling the 2.9 m
; entrance gap. The StaticBody3D blocks the FP CharacterBody3D from
; walking out into void (collision_layer 2 / store_fixtures, masked
; by the player CharacterBody3D's mask=3). The Interactable child
; shows an "Exit to Mall" prompt within the player's reticle range
; and routes the interaction back to the store controller, which
; releases the cursor and changes GameManager state to MALL_OVERVIEW.
; The door sits at Z=10.0, just inside the front wall plane at
; Z=10.05; the X gap (2.9 m at X=0) is disjoint from the front wall
; segments at X=±4.78 so colliders never overlap geometrically.
; The Interactable trigger volume (2.8 × 3.0 × 0.8) extends inward
; to Z=9.6 so the prompt shows from the player's bound z<=9.7.
; ============================================================

[node name="EntranceDoor" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 10.0)

[node name="DoorMesh" type="MeshInstance3D" parent="EntranceDoor"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1.75, 0)
mesh = SubResource("entrance_door_glass_mesh")
surface_material_override/0 = SubResource("entrance_door_glass_mat")

[node name="StaticBody3D" type="StaticBody3D" parent="EntranceDoor"]
collision_layer = 2
collision_mask = 0

[node name="CollisionShape3D" type="CollisionShape3D" parent="EntranceDoor/StaticBody3D"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1.75, 0)
