[sub_resource type="BoxMesh" id="slot_marker_mesh"]
size = Vector3(0.18, 0.12, 0.09)

; Shelf-slot interaction trigger volume. Sized to match the shipped
; shelf_slot.tscn component (0.3 m cube) so the player's reticle can lock onto
; a slot from a natural standing distance without having to align inside the
; fixture body. Width stays under the tightest neighbor spacing in the scene
; (ConsoleShelf at 0.3 m between slots) so adjacent slots touch but do not
; overlap; the InteractionRay's closest-collider-wins behaviour selects the
; correct slot.
