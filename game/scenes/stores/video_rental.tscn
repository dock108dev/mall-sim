display_name = "Snack Slot"

[node name="CollisionShape3D" type="CollisionShape3D" parent="Checkout/SnackSlot4"]
shape = SubResource("slot_collision")

[node name="Marker" type="MeshInstance3D" parent="Checkout/SnackSlot4"]
mesh = SubResource("slot_marker_mesh")
surface_material_override/0 = ExtResource("13")

[node name="CustomerWaitPosition" type="Marker3D" parent="Checkout/Register"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -1.15, 1.2)

; ============================================================
; Returns Bin
; Position: next to checkout counter
; ============================================================

[node name="ReturnsBin" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 1.5, 0, 2.2)

[node name="BinMesh" type="MeshInstance3D" parent="ReturnsBin"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.25, 0)
mesh = SubResource("returns_bin_mesh")
surface_material_override/0 = ExtResource("11")

[node name="ReturnsBinInteractable" type="Area3D" parent="ReturnsBin"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.25, 0)
collision_layer = 2
collision_mask = 0
script = ExtResource("4")

[node name="CollisionShape3D" type="CollisionShape3D" parent="ReturnsBin/ReturnsBinInteractable"]
shape = SubResource("returns_bin_collision")

; ============================================================
; Backroom Access Point
; Position: back-left corner
; ============================================================

[node name="BackroomDoor" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -4.5, 0, -3.0)

[node name="DoorMesh" type="MeshInstance3D" parent="BackroomDoor"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1.0, 0)
mesh = SubResource("door_mesh")
surface_material_override/0 = ExtResource("14")

[node name="BackroomInteractable" type="Area3D" parent="BackroomDoor"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1.0, 0)
collision_layer = 2
collision_mask = 0
script = ExtResource("3")
interaction_type = 3
display_name = "Backroom Door"

[node name="CollisionShape3D" type="CollisionShape3D" parent="BackroomDoor/BackroomInteractable"]
shape = SubResource("door_collision")

; ============================================================
; Navigation
; ============================================================

[node name="NavigationRegion3D" type="NavigationRegion3D" parent="."]
navigation_mesh = SubResource("nav_mesh")

; ============================================================
; Entry / Exit zone (front of store)
; ============================================================

[node name="EntryArea" type="Area3D" parent="." groups=["entry_area"]]
