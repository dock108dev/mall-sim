; ============================================================
; Register checkout zone
; ============================================================

[node name="RegisterArea" type="Area3D" parent="." groups=["register_area"]]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3.0, 1.0, 2.2)
