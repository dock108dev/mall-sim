[internationalization]

locale/translations=PackedStringArray("res://game/assets/localization/translations.en.en.translation", "res://game/assets/localization/translations.es.es.translation")

[layer_names]

3d_physics/layer_1="world_geometry"
3d_physics/layer_2="store_fixtures"
3d_physics/layer_3="player"
3d_physics/layer_4="customers"
3d_physics/layer_5="interactable_triggers"

[rendering]

textures/vram_compression/import_etc2_astc=true
lights_and_shadows/directional_shadow/size=2048
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=1
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=1
textures/default_filters/anisotropic_filtering_level=1
environment/ssao/quality=0
environment/ssil/quality=0
anti_aliasing/quality/msaa_3d=1
anti_aliasing/quality/use_debanding=true
environment/glow/upscale_mode=0
environment/defaults/default_clear_color=Color(0.1, 0.1, 0.12, 1)
environment/ssr/roughness_quality=0
