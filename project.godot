; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Mallcore Sim"
config/description="A retail simulator inspired by 2000s mall and store culture."
config/version="0.1.0"
run/main_scene="res://game/scenes/bootstrap/boot.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

DataLoaderSingleton="*res://game/autoload/data_loader.gd"
ContentRegistry="*res://game/autoload/content_registry.gd"
EventBus="*res://game/autoload/event_bus.gd"
GameManager="*res://game/autoload/game_manager.gd"
AudioManager="*res://game/autoload/audio_manager.gd"
Settings="*res://game/autoload/settings.gd"
EnvironmentManager="*res://game/autoload/environment_manager.gd"
CameraManager="*res://game/autoload/camera_manager.gd"
StaffManager="*res://game/autoload/staff_manager.gd"
ReputationSystemSingleton="*res://game/autoload/reputation_system.gd"
DifficultySystemSingleton="*res://game/autoload/difficulty_system.gd"
UnlockSystemSingleton="*res://game/autoload/unlock_system.gd"
CheckoutSystem="*res://game/autoload/checkout_system.gd"
OnboardingSystemSingleton="*res://game/autoload/onboarding_system.gd"
MarketTrendSystemSingleton="*res://game/autoload/market_trend_system.gd"
TooltipManager="*res://game/autoload/tooltip_manager.gd"
ObjectiveRail="*res://game/scenes/ui/objective_rail.tscn"
InteractionPrompt="*res://game/scenes/ui/interaction_prompt.tscn"
ObjectiveDirector="*res://game/autoload/objective_director.gd"
AuditOverlay="*res://game/autoload/audit_overlay.gd"
AuditLog="*res://game/autoload/audit_log.gd"
LedgerSystem="*res://game/autoload/ledger_system.gd"
EventLog="*res://game/autoload/event_log.gd"
SceneRouter="*res://game/autoload/scene_router.gd"
ErrorBanner="*res://game/autoload/error_banner.gd"
CameraAuthority="*res://game/autoload/camera_authority.gd"
InputFocus="*res://game/autoload/input_focus.gd"
StoreRegistry="*res://game/autoload/store_registry.gd"
StoreDirector="*res://game/autoload/store_director.gd"
GameState="*res://game/autoload/game_state.gd"
EmploymentSystem="*res://game/autoload/employment_system.gd"
PlatformSystem="*res://game/scripts/systems/platform_system.gd"
StoreCustomizationSystem="*res://game/scripts/systems/store_customization_system.gd"
ShiftSystem="*res://game/scripts/systems/shift_system.gd"
ManagerRelationshipManager="*res://game/autoload/manager_relationship_manager.gd"
MorningNotePanel="*res://game/scenes/ui/morning_note_panel.tscn"
MiddayEventSystem="*res://game/scripts/systems/midday_event_system.gd"
MiddayEventCard="*res://game/scenes/ui/midday_event_card.tscn"
FailCard="*res://game/scenes/ui/fail_card.tscn"
TutorialContextSystem="*res://game/autoload/tutorial_context_system.gd"
Day1ReadinessAudit="*res://game/autoload/day1_readiness_audit.gd"
HiddenThreadSystemSingleton="*res://game/autoload/hidden_thread_system.gd"
ReturnsSystem="*res://game/autoload/returns_system.gd"

[debug]

gdscript/warnings/unused_signal=0
walkable_mall=false

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[gui]

theme/custom="res://game/themes/mallcore_theme.tres"

