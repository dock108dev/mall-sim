{
  "run_name": "mall_sim_planning_40h",
  "project_name": "mall-sim",
  "run_type": "planning",
  "duration_budget_hours": 40,
  "checkpoint_interval_minutes": 30,
  "dry_run": false,

  "claude_cli_command": "claude",
  "claude_model": "opus",
  "claude_timeout_seconds": 1800,

  "retry_max_attempts": 2,
  "retry_delay_seconds": 30,
  "max_consecutive_failures": 3,

  "universe_manifest": "planning/manifests/final-issue-universe.json",
  "freeze_manifest": "planning/manifests/closed-universe-freeze.json",
  "wave_manifest": "planning/manifests/final-wave-plan.json",
  "milestone_manifest": "planning/manifests/final-milestone-plan.json",
  "dependency_manifest": "planning/manifests/final-dependency-graph.json",

  "start_wave": "wave-1",

  "validation_at_checkpoints": true,
  "generate_reports": true,

  "stop_conditions": [
    "budget_exhausted",
    "all_issues_processed",
    "max_consecutive_failures"
  ],

  "finalization_budget_percent": 10,

  "notes": "Primary 40-hour planning run for mall-sim project. Open planning window: may create new issues, tasks, docs. Finalization at 90% budget: no new work, only consolidation."
}
